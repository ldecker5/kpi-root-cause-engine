    },
    {
        "id": "stable_aov",
        "query": "If average order value is stable but revenue drops, what should we check?",
        "expected_keywords": ["traffic", "conversion", "avg_order_value"],
        "category": "standard",
    },
    {
        "id": "west_region_marketing",
        "query": "What explains the revenue decline in the West region?",
        "expected_keywords": ["west", "marketing", "revenue"],
        "category": "standard",
    },
    {
        "id": "vague_prompt",
        "query": "How are things looking?",
        "expected_keywords": [],
        "category": "edge_case",
    },
    {
        "id": "missing_metric",
        "query": "Show me vibe_score and satisfaction_rating for April 2024.",
        "expected_keywords": [],
        "category": "failure_mode",
    },
]


def generate_baseline_response(query):
    prompt = f"""You are a KPI analysis assistant.

Answer the user's question directly using general reasoning only.
Do not use tools or retrieval.
Be clear and structured.

User query:
{query}

Output format:
Summary
Evidence
Plausible explanations
Recommendations
"""
    response = client.chat.completions.create(
        model="gpt-4o-mini",
        messages=[{"role": "user", "content": prompt}],
        max_tokens=700,
    )
    return response.choices[0].message.content


def keyword_score(text, expected_keywords):
    if not expected_keywords:
        return 1.0
    text = text.lower()
    hits = sum(1 for kw in expected_keywords if kw.lower() in text)
    return round(hits / len(expected_keywords), 4)


def coherence_score(text):
    text = text.lower()
    sections = ["summary", "evidence", "recommend", "explanation"]
    hits = sum(1 for s in sections if s in text)
    return round(hits / len(sections), 4)


def faithfulness_score(support_obj, final_text):
    support_text = json.dumps(support_obj).lower()
    tokens = [w.strip(".,:;()[]") for w in final_text.lower().split()]
    tokens = [w for w in tokens if len(w) > 5][:25]
    if not tokens:
        return 0.0
    hits = sum(1 for w in tokens if w in support_text)
    return round(min(1.0, hits / len(tokens)), 4)


def evaluate_retrieval():
    return {
        "skipped": True,
        "reason": "RAG not used for this Milestone 11 evaluation. Comparison focuses on baseline LLM vs. no-RAG ReAct agent."
    }


def evaluate_generation_and_agent():
    rows = []

    for case in TEST_SCENARIOS:
        baseline = ""
        baseline_error = None
        agent_result = None
        agent_error = None

        try:
            baseline = generate_baseline_response(case["query"])
        except Exception as e:
            baseline_error = str(e)
            print(f"[SKIP] Baseline evaluation unavailable for {case['id']}: {baseline_error}")

        try:
            agent_result = run_agent(
                system_prompt=REACT_AGENT_SYSTEM_PROMPT,
                user_prompt=case["query"],
                debug=False,
                return_state=True,
            )
        except Exception as e:
            agent_error = str(e)
            print(f"[SKIP] Agent evaluation unavailable for {case['id']}: {agent_error}")

        baseline_rel = keyword_score(baseline, case["expected_keywords"]) if baseline else None
        agent_rel = keyword_score(agent_result["final_answer"], case["expected_keywords"]) if agent_result else None

        baseline_coh = coherence_score(baseline) if baseline else None
        agent_coh = coherence_score(agent_result["final_answer"]) if agent_result else None

        baseline_faith = None
        agent_faith = faithfulness_score(agent_result["state"], agent_result["final_answer"]) if agent_result else None

        agent_actions = len(agent_result["state"]["actions"]) if agent_result else None
        agent_observations = len(agent_result["state"]["observations"]) if agent_result else None
        agent_task_complete = (
            1 if agent_result["final_answer"] and "stopped" not in agent_result["final_answer"].lower() else 0
        ) if agent_result else None

        agent_preferred_over_baseline = None
        if (
            baseline_rel is not None and baseline_coh is not None
            and agent_rel is not None and agent_coh is not None and agent_faith is not None
        ):
            agent_preferred_over_baseline = 1 if (agent_rel + agent_coh + agent_faith) > (baseline_rel + baseline_coh) else 0

        rows.append({
            "scenario_id": case["id"],
            "category": case["category"],
            "baseline_relevance": baseline_rel,
            "agent_relevance": agent_rel,
            "baseline_coherence": baseline_coh,
            "agent_coherence": agent_coh,
            "baseline_faithfulness": baseline_faith,
            "agent_faithfulness": agent_faith,
            "agent_actions": agent_actions,
            "agent_observations": agent_observations,
            "agent_task_complete": agent_task_complete,
            "agent_preferred_over_baseline": agent_preferred_over_baseline,
            "baseline_error": baseline_error,
            "agent_error": agent_error,
        })

    return rows


def save_csv(rows, path):
    Path(path).parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
        writer.writeheader()
        writer.writerows(rows)


def save_summary(rows, retrieval, path):
    Path(path).parent.mkdir(parents=True, exist_ok=True)

    def avg(key):
        vals = [r[key] for r in rows if r[key] is not None]
        return round(sum(vals) / len(vals), 4) if vals else None

    summary = {
        "retrieval_skipped": retrieval.get("skipped", False),
        "retrieval_reason": retrieval.get("reason"),
        "avg_baseline_relevance": avg("baseline_relevance"),
        "avg_agent_relevance": avg("agent_relevance"),
        "avg_baseline_coherence": avg("baseline_coherence"),
        "avg_agent_coherence": avg("agent_coherence"),
        "avg_baseline_faithfulness": avg("baseline_faithfulness"),
        "avg_agent_faithfulness": avg("agent_faithfulness"),
        "avg_agent_actions": avg("agent_actions"),
        "avg_agent_observations": avg("agent_observations"),
        "agent_task_completion_rate": avg("agent_task_complete"),
        "agent_win_rate_over_baseline": avg("agent_preferred_over_baseline"),
        "failure_modes": [r["scenario_id"] for r in rows if r["category"] == "failure_mode"],
        "edge_cases": [r["scenario_id"] for r in rows if r["category"] == "edge_case"],
        "baseline_eval_errors": {r["scenario_id"]: r["baseline_error"] for r in rows if r["baseline_error"] is not None},
        "agent_eval_errors": {r["scenario_id"]: r["agent_error"] for r in rows if r["agent_error"] is not None},
    }

    with open(path, "w") as f:
        json.dump(summary, f, indent=2)


if __name__ == "__main__":
    retrieval = evaluate_retrieval()
    rows = evaluate_generation_and_agent()

    metrics_path = "evaluation/results/milestone11_metrics.csv"
    summary_path = "evaluation/results/milestone11_summary.json"

    save_csv(rows, metrics_path)
    save_summary(rows, retrieval, summary_path)

    print("Milestone 11 evaluation complete.")
    print(f"Metrics saved to: {metrics_path}")
    print(f"Summary saved to: {summary_path}")

    with open(summary_path, "r") as f:
        summary = json.load(f)

    print("\n=== SUMMARY ===")
    print(json.dumps(summary, indent=2))
