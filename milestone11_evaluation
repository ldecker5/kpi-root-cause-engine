import csv
import json
from pathlib import Path

from src.agent import run_agent
from src.rag_pipeline import RAGPipeline
from src.prompts import REACT_AGENT_SYSTEM_PROMPT

TEST_SCENARIOS = [
    {
        "id": "revenue_drop_mobile",
        "query": "Revenue dropped after April 20. Identify the likely drivers.",
        "expected_keywords": ["revenue", "conversion", "marketing"],
    },
    {
        "id": "stable_aov",
        "query": "If average order value is stable but revenue drops, what should we check?",
        "expected_keywords": ["traffic", "conversion", "avg_order_value"],
    },
    {
        "id": "west_region",
        "query": "What explains the revenue decline in the West region?",
        "expected_keywords": ["west", "marketing", "revenue"],
    },
    {
        "id": "edge_missing_context",
        "query": "How are things looking?",
        "expected_keywords": [],
    },
]

def simple_keyword_relevance_score(text, expected_keywords):
    if not expected_keywords:
        return 1.0
    hits = sum(1 for kw in expected_keywords if kw.lower() in text.lower())
    return hits / len(expected_keywords)

def simple_coherence_score(text):
    required_sections = ["summary", "evidence", "recommend", "explanation"]
    hits = sum(1 for s in required_sections if s in text.lower())
    return hits / len(required_sections)

def simple_faithfulness_score(agent_state_or_rag_context, final_text):
    # simple placeholder heuristic
    support_text = json.dumps(agent_state_or_rag_context).lower()
    keywords = [w for w in final_text.lower().split() if len(w) > 5][:20]
    if not keywords:
        return 0.0
    hits = sum(1 for w in keywords if w in support_text)
    return min(1.0, hits / max(1, len(keywords)))

def evaluate_rag():
    rag = RAGPipeline()
    rag.build_or_load()
    retrieval = rag.evaluate_retrieval(rag.DEFAULT_TEST_SET if hasattr(rag, "DEFAULT_TEST_SET") else [], k=5)
    return retrieval

def evaluate_agent_and_generation():
    rag = RAGPipeline()
    rag.build_or_load()

    rows = []

    for case in TEST_SCENARIOS:
        baseline = rag.generate_baseline_response(case["query"])
        rag_result = rag.generate_rag_response(case["query"], k=5)

        agent_result = run_agent(
            system_prompt=REACT_AGENT_SYSTEM_PROMPT,
            user_prompt=case["query"],
            debug=False,
            return_state=True,
        )

        baseline_rel = simple_keyword_relevance_score(baseline, case["expected_keywords"])
        rag_rel = simple_keyword_relevance_score(rag_result["response"], case["expected_keywords"])
        agent_rel = simple_keyword_relevance_score(agent_result["final_answer"], case["expected_keywords"])

        baseline_coh = simple_coherence_score(baseline)
        rag_coh = simple_coherence_score(rag_result["response"])
        agent_coh = simple_coherence_score(agent_result["final_answer"])

        rag_faith = simple_faithfulness_score(rag_result["context"], rag_result["response"])
        agent_faith = simple_faithfulness_score(agent_result["state"], agent_result["final_answer"])

        rows.append({
            "scenario_id": case["id"],
            "baseline_relevance": baseline_rel,
            "rag_relevance": rag_rel,
            "agent_relevance": agent_rel,
            "baseline_coherence": baseline_coh,
            "rag_coherence": rag_coh,
            "agent_coherence": agent_coh,
            "rag_faithfulness": rag_faith,
            "agent_faithfulness": agent_faith,
            "agent_actions": len(agent_result["state"]["actions"]),
            "agent_observations": len(agent_result["state"]["observations"]),
        })

    return rows

def save_results(rows, outpath="evaluation/results/milestone11_results.csv"):
    Path(outpath).parent.mkdir(parents=True, exist_ok=True)
    with open(outpath, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
        writer.writeheader()
        writer.writerows(rows)

if __name__ == "__main__":
    rows = evaluate_agent_and_generation()
    save_results(rows)
    print("Saved Milestone 11 results.")
